{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tab-title.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-commit-vault.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-open-obsidian.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tab-title.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-verification-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
