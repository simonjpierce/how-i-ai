{
  "_comment": "Per-vault config written by /onboard. Skills read paths from this file rather than hard-coding them, so the user can rename folders without breaking anything. Keys are stable; values are user-specific.",

  "vault": {
    "path": "{{VAULT_ABSOLUTE_PATH}}",
    "name": "{{VAULT_NAME}}",
    "url_encoded_name": "{{VAULT_NAME_URL_ENCODED}}"
  },

  "folders": {
    "inbox": "INBOX",
    "ai_workflow": "AI_WORKFLOW",
    "logs_relative": "AI_WORKFLOW/CLAUDE",
    "specs_relative": "AI_WORKFLOW/SPECS",
    "templates_relative": "AI_WORKFLOW/templates"
  },

  "logs": {
    "session_handoff": "Session Handoff Log.md",
    "decision": "Decision Log.md",
    "friction": "Friction Log.md"
  },

  "_domains_comment": "domains is populated from discovery Q2 if user opted into the domain pass. Empty array if they chose root-CLAUDE.md-only. /onboard substitutes one entry per domain; remove this template entry when writing the live config.",
  "domains": [
    {
      "folder_name": "{{DOMAIN_FOLDER_NAME}}",
      "display_name": "{{DOMAIN_DISPLAY_NAME}}",
      "claude_md_path": "{{DOMAIN_FOLDER_NAME}}/CLAUDE.md"
    }
  ],

  "_tools_comment": "Tool integrations discovered during /onboard Q7. Empty/null values mean the tool isn't available — skills check for these and degrade gracefully (e.g. /research skips its Codex pass when codex_available is false; /todo falls back to writing to vault TODO.md when task_manager is null or unrecognised). task_manager values: 'things3', 'todoist', 'apple_reminders', 'vault_todo', or null. Other task managers (Asana, Linear, Notion, etc.) aren't routed natively yet — set 'vault_todo' for now and ask Claude to add a branch if you'd like first-class routing.",
  "tools": {
    "task_manager": null,
    "codex_available": false,
    "gemini_available": false
  },

  "install": {
    "version": "v0",
    "installed_at": "{{INSTALL_ISO_TIMESTAMP}}",
    "self_improvement_followup_scheduled_for": "{{INSTALL_DATE_PLUS_14_DAYS}}"
  },

  "_features_comment": "Booleans below are real JSON booleans, not strings. /onboard substitutes {{TRUE_OR_FALSE}} placeholders with the literal token `true` or `false` (no quotes). For zero domains, write `\"domains\": []` and skip the placeholder block entirely. `is_simon` should always be false for newcomer installs — it gates Simon-personal behaviours in /document and /update (Things 3 calls, simonjpierce/claude-code-config commits, Daily Log housekeeping, voice references). Setting it true on any other machine will cause those skills to attempt operations against folders/repos/tools that don't exist there.",
  "features": {
    "auto_approval_mode_recommended": true,
    "domain_folders_opted_in": {{TRUE_OR_FALSE}},
    "numbered_folder_prefixes": {{TRUE_OR_FALSE}},
    "is_simon": false
  }
}
